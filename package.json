{
  "type": "module",
  "packageManager": "pnpm@11.0.3",
  "name": "vite-starter",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "author": {
    "name": "Erwan Jugand",
    "url": "https://erwan-jugand.fr/"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check:ts": "tsc --noEmit",
    "check:prettier": "prettier --check .",
    "check:lint": "oxlint",
    "check:stylelint": "stylelint **/*.{scss,sass}",
    "check:all": "pnpm check:ts && pnpm check:prettier && pnpm check:lint && pnpm check:stylelint",
    "fix:prettier": "prettier --log-level warn --write .",
    "fix:lint": "pnpm check:lint --fix --fix-suggestions",
    "fix:stylelint": "pnpm check:stylelint --fix",
    "fix:all": "pnpm fix:prettier && pnpm fix:lint && pnpm fix:stylelint"
  },
  "devDependencies": {
    "@erwanjugand/prettier-config": "1.0.0",
    "@prettier/plugin-oxc": "0.1.4",
    "oxlint": "1.62.0",
    "prettier": "3.8.3",
    "sass-embedded": "1.99.0",
    "stylelint": "17.9.1",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-order": "8.1.1",
    "the-new-css-reset": "1.11.3",
    "typescript": "6.0.3",
    "vite": "8.0.10"
  }
}
